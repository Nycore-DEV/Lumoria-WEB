generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Vercel serverless functions have an ephemeral filesystem, so SQLite will
  // NOT persist in production. Use a hosted Postgres (Neon, Vercel Postgres,
  // Supabase, etc.) in production. SQLite is fine for local development only
  // if you switch the provider below back to "sqlite" and file:./dev.db.
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Settings {
  id             Int      @id @default(1)
  serverName     String   @default("Nama Server")
  tagline        String?  @default("Server Minecraft Survival, Semi Vanilla, Anti-Toxic.")
  logoUrl        String?
  faviconUrl     String?
  bannerUrl      String?
  backgroundUrl  String?
  themeColor     String   @default("#2FBF71")
  heroTitle      String?  @default("Selamat Datang di Server")
  heroSubtitle   String?  @default("Bangun, bertahan hidup, dan berpetualang bersama ratusan pemain lainnya.")
  aboutTitle     String?  @default("Tentang Server")
  aboutContent   String?  @db.Text
  footerText     String?  @default("Server Minecraft terbaik untuk membangun komunitas dan petualangan.")
  discordUrl     String?
  twitterUrl     String?
  instagramUrl   String?
  youtubeUrl     String?
  tiktokUrl      String?
  contactEmail   String?
  updatedAt      DateTime @updatedAt
}

model ServerInfo {
  id            Int      @id @default(1)
  ip            String?  @default("play.example.net")
  bedrockPort   String?
  version       String?  @default("1.21.x")
  gameMode      String?  @default("Survival")
  status        String   @default("online") // online | offline | maintenance
  onlinePlayers Int      @default(0)
  maxPlayers    Int      @default(200)
  location      String?  @default("Singapore")
  extra         String?  @db.Text
  updatedAt     DateTime @updatedAt
}

model ActionButton {
  id     String  @id @default(cuid())
  label  String
  url    String
  type   String  @default("custom") // join | discord | vote | custom
  active Boolean @default(true)
  order  Int     @default(0)
}

model Feature {
  id          String @id @default(cuid())
  icon        String? // lucide icon name, e.g. "Swords"
  imageUrl    String?
  title       String
  description String  @db.Text
  order       Int     @default(0)
}

model StaffMember {
  id          String  @id @default(cuid())
  gamertag    String
  role        String
  description String? @db.Text
  skinUrl     String?
  order       Int     @default(0)
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  type      String   @default("info") // event | maintenance | update | giveaway | info
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FaqItem {
  id       String @id @default(cuid())
  question String
  answer   String @db.Text
  order    Int    @default(0)
}
