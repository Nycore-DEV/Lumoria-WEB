# Koneksi database Postgres (wajib untuk produksi/Vercel).
# Bisa didapat gratis dari Neon (neon.tech), Vercel Postgres, atau Supabase.
# Untuk uji coba lokal cepat, kamu bisa memakai SQLite:
#   1. Ganti provider di prisma/schema.prisma menjadi "sqlite"
#   2. Set DATABASE_URL="file:./dev.db"
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# String acak & panjang untuk menandatangani session admin.
# Generate contoh: openssl rand -base64 32
ADMIN_JWT_SECRET="ganti-dengan-string-acak-yang-sangat-panjang"

# Catatan: kamu TIDAK perlu mengisi username/password admin di sini.
# Setelah aplikasi berjalan, buka /admin/setup di browser untuk membuat
# akun admin pertama secara langsung (aman & hanya bisa dipakai sekali).
# Variabel di bawah ini hanya dipakai OPSIONAL oleh `npm run db:seed`
# untuk mengisi beberapa contoh fitur/FAQ saat development lokal.
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="admin123"
